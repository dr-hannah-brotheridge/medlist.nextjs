# Copy to .env.local for local builds, and set the same vars in Vercel
# (Project → Settings → Environment Variables).

# Public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Server-only — NEVER prefix with NEXT_PUBLIC_. Used by /admin and account deletion.
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Comma-separated emails allowed to access /admin
ADMIN_EMAILS=you@example.com

# Server-only. Needed later to enable Claude enrichment in /admin/populate.
ANTHROPIC_API_KEY=
