# Copy to .env.local for local builds, and set the same vars in Vercel
# (Project → Settings → Environment Variables).

# Public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Server-only — NEVER prefix with NEXT_PUBLIC_. Used by /admin and account deletion.
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Comma-separated emails allowed to access /admin
ADMIN_EMAILS=you@example.com

# PWA / Auth: Supabase Dashboard config required for custom domains.
# Go to Authentication -> URL Configuration -> Redirect URLs and add:
#   https://www.scriptpal.co.nz/auth/callback
#   https://scriptpal.co.nz/auth/callback
#   https://scriptpal-oh4sh85wg-dr-hannah-brotheridges-projects.vercel.app/auth/callback
# Set Site URL to https://scriptpal.co.nz

# Server-only. Needed later to enable Claude enrichment in /admin/populate.
ANTHROPIC_API_KEY=

# NeuralWatt GLM-5.2 endpoint for the educational-db enrichment script
# (scripts/build-educational-db.js). Server-only — never prefix NEXT_PUBLIC_.
NEURALWATT_BASE_URL=https://api.neuralwatt.com/v1
NEURALWATT_API_KEY=
NEURALWATT_MODEL=GLM-5.2
